@startuml Flow_출석
!theme plain
skinparam backgroundColor #FEFEFE

title 출석 화면 흐름 (Mobile)

[*] --> 출석메인

state "스터디원 플로우" as 스터디원 {
    [*] --> 출석하기

    state 출석하기 {
        [*] --> BLE스캔모드
        BLE스캔모드 : BLE 비콘 스캔
        BLE스캔모드 : "스터디장 비콘을 찾는 중..."
        BLE스캔모드 --> 비콘감지
    }

    비콘감지 --> 출석체크요청 : 비콘 신호 감지
    출석체크요청 --> 출석성공화면 : 출석 완료

    state 출석성공화면 {
        [*] --> 출석확인
        출석확인 : 출석 완료 애니메이션
        출석확인 : 현재 출석 현황
    }
}

state "스터디장 플로우" as 스터디장 {
    [*] --> 출석체크시작

    state 출석체크시작 {
        [*] --> BLE비콘모드
        BLE비콘모드 : BLE 비콘 신호 발신
        BLE비콘모드 : "출석 체크 진행 중..."
    }

    BLE비콘모드 --> 출석알림 : 스터디원 출석 감지
    출석알림 --> BLE비콘모드 : 계속 체크

    BLE비콘모드 --> 실시간출석현황 : 현황 보기
    BLE비콘모드 --> 수동출석변경 : 수동 변경

    state 실시간출석현황 {
        [*] --> 출석자목록
        출석자목록 : 출석/미출석 실시간
        출석자목록 : 출석률 표시
    }

    state 수동출석변경 {
        [*] --> 멤버선택
        멤버선택 --> 상태변경 : 출석 상태 선택
    }
}

state "셀프 출석 플로우" as 셀프출석 {
    [*] --> 셀프출석화면
    셀프출석화면 : 스터디장 미접속 15분 후
    셀프출석화면 : 자동 활성화
    셀프출석화면 --> 셀프출석완료 : 출석 버튼
}

출석메인 --> 출석캘린더

state 출석캘린더 {
    [*] --> 캘린더뷰
    캘린더뷰 : 출석/미출석 표시
    캘린더뷰 : 월별 출석률
    캘린더뷰 --> 결석소명 : 미출석 날짜 선택
}

state 결석소명 {
    [*] --> 소명작성
    소명작성 : 사유 입력
    소명작성 --> 소명제출
}

state "세션 메모 (오프라인)" as 세션메모 {
    [*] --> 메모작성화면
    메모작성화면 : 오늘 뭐 했는지 한 줄 메모
    메모작성화면 --> 메모저장 : 저장
    메모저장 --> 메모목록 : 다른 멤버 메모 보기
}

출석성공화면 --> 세션메모 : 오프라인 세션
실시간출석현황 --> 세션메모 : 메모 보기

note right of 세션메모
  오프라인 스터디 종료 후
  참석자들이 한 줄 메모 작성
  AI가 스터디 내용 파악에 활용
end note

note right of 셀프출석
  스터디장 미접속 15분 후
  자동으로 셀프 출석 활성화
end note

note bottom of 출석캘린더
  출석률 50% 이하 시
  시스템 추방 예고 알림
end note

@enduml
