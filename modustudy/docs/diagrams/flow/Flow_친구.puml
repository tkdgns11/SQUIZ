@startuml Flow_친구
!theme plain
skinparam backgroundColor #FEFEFE

title 친구 화면 흐름

[*] --> 친구메뉴

state 친구메뉴 {
    [*] --> 친구목록탭
    친구목록탭 --> 친구검색탭 : 탭 전환
    친구목록탭 --> 요청관리탭 : 탭 전환
    친구목록탭 --> 차단목록탭 : 탭 전환
    친구검색탭 --> 친구목록탭 : 탭 전환
    요청관리탭 --> 친구목록탭 : 탭 전환
    차단목록탭 --> 친구목록탭 : 탭 전환
}

state 친구목록탭 {
    [*] --> 친구목록
    친구목록 : 온라인/오프라인 구분
    친구목록 : 온라인 상태 표시
    친구목록 --> 친구프로필 : 친구 선택
    친구목록 --> 친구삭제확인 : 삭제 버튼
    친구삭제확인 --> 친구목록 : 확인/취소
}

친구프로필 --> DM대화 : DM 버튼

state 친구검색탭 {
    [*] --> 검색입력
    검색입력 : 닉네임으로 검색
    검색입력 --> 검색결과 : 검색
    검색결과 : 검색 허용 사용자만 노출
    검색결과 --> 사용자프로필 : 사용자 선택
}

state 사용자프로필 {
    [*] --> 프로필정보
    프로필정보 : 닉네임/프로필이미지
    프로필정보 : 온라인 상태
    프로필정보 --> 친구요청완료 : 친구 요청
    프로필정보 --> 차단완료 : 차단하기
}

state 요청관리탭 {
    [*] --> 받은요청
    받은요청 --> 보낸요청 : 탭 전환
    보낸요청 --> 받은요청 : 탭 전환

    state 받은요청 {
        [*] --> 받은요청목록
        받은요청목록 --> 요청수락 : 수락
        받은요청목록 --> 요청거절 : 거절
        요청수락 --> 받은요청목록
        요청거절 --> 받은요청목록
    }

    state 보낸요청 {
        [*] --> 보낸요청목록
        보낸요청목록 : 대기중/수락됨/거절됨
        보낸요청목록 --> 요청취소 : 취소
        요청취소 --> 보낸요청목록
    }
}

state 차단목록탭 {
    [*] --> 차단목록
    차단목록 --> 차단해제확인 : 해제 버튼
    차단해제확인 --> 차단목록 : 확인/취소
}

note right of 검색결과
  is_searchable = true인
  사용자만 검색됨
end note

note right of 친구프로필
  친구인 경우에만
  DM 전송 가능
end note

@enduml
