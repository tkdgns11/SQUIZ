@startuml Flow_퀴즈
!theme plain
skinparam backgroundColor #FEFEFE

title 퀴즈 화면 흐름

[*] --> 퀴즈홈

state 퀴즈홈 {
    [*] --> 퀴즈메인
    퀴즈메인 : 진행중 대회
    퀴즈메인 : 오답 노트 바로가기
    퀴즈메인 : 내 대회 기록
}

퀴즈홈 --> 대회목록 : 대회 탭

state 대회목록 {
    [*] --> 대회리스트
    대회리스트 : 진행중/예정/종료 필터
    대회리스트 --> 대회상세 : 대회 선택
}

대회상세 --> 대회대기실 : 참여하기

state 대회대기실 {
    [*] --> 참가자대기
    참가자대기 : 참가자 목록
    참가자대기 : 대회 시작 대기
    참가자대기 --> 닉네임입력 : 비로그인 시
    닉네임입력 --> 참가자대기 : 입력 완료
}

대회대기실 --> 대회진행 : 대회 시작

state 대회진행 {
    [*] --> 문제표시
    문제표시 : 문제 내용
    문제표시 : 제한 시간 타이머
    문제표시 : 현재 순위

    문제표시 --> 답안선택 : 보기 선택
    답안선택 --> 정답확인 : 시간 종료
    정답확인 --> 다음문제 : 다음
    다음문제 --> 문제표시 : 반복
}

대회진행 --> 대회결과 : 모든 문제 완료

state 대회결과 {
    [*] --> 최종결과
    최종결과 : 최종 순위
    최종결과 : 총 점수
    최종결과 : 정답률

    최종결과 --> 결과상세 : 상세 보기

    state 결과상세 {
        [*] --> 문제별결과
        문제별결과 : 틀린 문제 표시
        문제별결과 : 정답/해설
        문제별결과 : 문제별 정답률
    }
}

퀴즈홈 --> 역대순위 : 역대 순위 탭

state 역대순위 {
    [*] --> 과거대회목록
    과거대회목록 --> 대회별순위 : 대회 선택
    대회별순위 : 전체 참가자 순위
}

퀴즈홈 --> 내대회기록 : 내 기록 탭

state 내대회기록 {
    [*] --> 참여대회목록
    참여대회목록 : 점수/순위 히스토리
    참여대회목록 --> 대회결과 : 상세 보기
}

note right of 대회진행
  WebSocket 실시간 통신
  문제별 제한시간 적용
end note

note right of 닉네임입력
  비로그인 사용자도
  퀴즈 대회 참여 가능
end note

@enduml
