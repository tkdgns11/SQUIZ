@startuml UC_미팅
!theme plain
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

title 미팅 시스템 유스케이스

actor "스터디원" as member
actor "스터디장" as leader
actor "AI 시스템" as ai <<시스템>>

rectangle "미팅 진행" {
    usecase "미팅 시작" as UC1
    usecase "미팅 참여" as UC2
    usecase "미팅 종료" as UC3
    usecase "화면 공유" as UC4
    usecase "키워드 설정" as UC5
}

rectangle "STT/녹화" {
    usecase "실시간 STT 표시" as UC10
    usecase "발언 기록 저장" as UC11
    usecase "활동사진 캡처" as UC12
}

rectangle "미팅 기록" {
    usecase "미팅 기록 목록 조회" as UC20
    usecase "미팅 상세 조회" as UC21
    usecase "미팅 요약 조회" as UC22
    usecase "전문 조회" as UC23
    usecase "액션아이템 조회" as UC24
    usecase "활동사진 갤러리" as UC25
}

' 스터디원
member --> UC2
member --> UC4
member --> UC20
member --> UC21
member --> UC22
member --> UC23
member --> UC24
member --> UC25

' 스터디장
leader --> UC1
leader --> UC3
leader --> UC5
leader --> UC12

' AI 시스템
ai --> UC10
ai --> UC11
UC3 ..> UC22 : <<include>>\n미팅 종료 시 자동 생성

note right of UC22
  AI가 미팅 내용 자동 요약
  키워드 기반 중요 내용 추출
end note

note right of UC12
  보고서용 활동사진
  자동/수동 캡처
end note

@enduml
