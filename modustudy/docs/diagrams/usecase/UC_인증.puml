@startuml UC_인증
!theme plain
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

title 인증 시스템 유스케이스

actor "사용자" as user
actor "소셜 OAuth\n(네이버/카카오/구글)" as social_oauth <<시스템>>
actor "소속 OAuth\n(SSAFY/네부캠 등)" as org_oauth <<시스템>>

rectangle "인증 시스템" {
    usecase "소셜 로그인" as UC1
    usecase "소셜 OAuth 인증" as UC2
    usecase "이메일+비밀번호 로그인" as UC1_1
    usecase "추가 정보 입력\n(최초 로그인)" as UC3
    usecase "자동 로그인" as UC4
    usecase "로그아웃" as UC5
    usecase "토큰 갱신" as UC6
    usecase "소속 인증" as UC7
    usecase "소속 인증 해제" as UC8
}

rectangle "계정 관리" {
    usecase "소셜 계정 연동" as UC10
    usecase "소셜 계정 연동 해제" as UC11
    usecase "비밀번호 설정" as UC12
    usecase "비밀번호 변경" as UC13
    usecase "연동 계정 목록 조회" as UC14
}

user --> UC1
user --> UC1_1
user --> UC4
user --> UC5
user --> UC7
user --> UC8
user --> UC10
user --> UC11
user --> UC12
user --> UC13
user --> UC14

UC1 ..> UC2 : <<include>>
UC2 --> social_oauth
UC1 ..> UC3 : <<extend>>\n최초 로그인 시
UC1_1 ..> UC12 : <<extend>>\n비밀번호 미설정 시

UC7 --> org_oauth

note right of UC3
  닉네임 입력
end note

note right of UC4
  앱 재실행 시
  저장된 토큰으로 자동 로그인
end note

note right of UC7
  소속 전용 스터디
  개설/가입 시 필요
  (마이페이지에서도 가능)
end note

note right of UC10
  네이버/카카오/구글
  여러 계정 연동 가능
end note

note right of UC12
  소셜 로그인만 사용 중일 때
  이메일 로그인용 비밀번호 설정
end note

@enduml
