@startuml UC_친구DM
!theme plain
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

title 친구 & DM 유스케이스

actor "로그인 사용자" as user

rectangle "친구 관리" {
    usecase "사용자 검색" as UC1
    usecase "친구 요청 보내기" as UC2
    usecase "친구 요청 수락" as UC3
    usecase "친구 요청 거절" as UC4
    usecase "친구 목록 조회" as UC5
    usecase "받은 요청 조회" as UC6
    usecase "보낸 요청 조회" as UC7
    usecase "친구 삭제" as UC8
    usecase "사용자 차단" as UC9
    usecase "차단 해제" as UC10
    usecase "차단 목록 조회" as UC11
}

rectangle "DM (1:1 메시지)" {
    usecase "DM 대화 목록 조회" as UC20
    usecase "DM 대화 시작" as UC21
    usecase "메시지 전송" as UC22
    usecase "메시지 조회" as UC23
    usecase "메시지 읽음 처리" as UC24
    usecase "메시지 삭제" as UC25
    usecase "대화 삭제" as UC26
}

' 친구 관리
user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC5
user --> UC6
user --> UC7
user --> UC8
user --> UC9
user --> UC10
user --> UC11

' DM
user --> UC20
user --> UC21
user --> UC22
user --> UC23
user --> UC24
user --> UC25
user --> UC26

' 관계
UC2 ..> UC1 : <<include>>\n검색 후 요청
UC21 ..> UC5 : <<include>>\n친구 중 선택
UC22 ..> UC21 : <<extend>>\n대화 시작 시

note right of UC1
  is_searchable = true인
  사용자만 검색됨
end note

note bottom of UC21
  친구 관계인 사용자에게만
  DM 전송 가능
end note

note right of UC9
  차단 시:
  - 친구 요청 불가
  - DM 전송 불가
  - 검색 결과에서 제외
end note

note bottom of UC25
  본인이 보낸
  메시지만 삭제 가능
end note

note bottom of UC26
  본인 기준으로만 삭제
  상대방에게는 유지
end note

@enduml
